            },
        }

        if APP_BASE_URL:
            payload["callback_url"] = f"{APP_BASE_URL}/paystack/callback"

        r = requests.post(PAYSTACK_INIT_URL, headers=paystack_headers(), json=payload, timeout=30)
        resp = r.json() if r.content else {}

        if r.status_code >= 400 or not resp.get("status"):
            # update payment to init_failed
            supabase.table("payments").update({
                "status": "init_failed",
                "raw_event": {
                    "source": "initialize",
                    "paystack_init_failed": resp,
                    "http_status": r.status_code,
                }
            }).eq("reference", reference).execute()

            return jsonify({
                "status": "error",
                "error": "paystack_init_failed",
                "reference": reference,
                "detail": resp
            }), 502

        auth_url = resp["data"]["authorization_url"]
        # Paystack returns a reference; we forced ours, but keep it future-proof:
        paystack_ref = resp["data"].get("reference") or reference

        # If Paystack ever changes/overrides reference, keep DB consistent with the ref used in webhook
        # (Webhook will send Paystack's reference)
        if paystack_ref != reference:
            # Rare, but handle it by switching our stored reference to Paystack's
            # This assumes "reference" is NOT a PK constraint that blocks updates.
            supabase.table("payments").update({
                "reference": paystack_ref,
                "status": "pending",
                "raw_event": {"source": "initialize", "paystack_init": resp["data"]},
            }).eq("reference", reference).execute()
            reference = paystack_ref
        else:
            supabase.table("payments").update({
                "status": "pending",
                "raw_event": {"source": "initialize", "paystack_init": resp["data"]},
            }).eq("reference", reference).execute()

        return jsonify({
            "status": "ok",
            "plan": plan,
            "reference": reference,
            "authorization_url": auth_url
        }), 200

    except Exception as e:
        return jsonify({"status": "error", "error": str(e)}), 500
