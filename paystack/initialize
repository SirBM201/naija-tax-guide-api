def paystack_initialize():
    """
    Paystack initialize (schema-safe):
    - inserts row into public.payments (status=initiated)
    - calls Paystack initialize
    - updates the same row to status=pending and stores paystack init response in raw_event
    - returns authorization_url + reference
    """
