    wa_phone = normalize_wa_phone(safe_text(data.get("wa_phone")))
    plan = safe_text(data.get("plan")).lower()

    if not PAYSTACK_SECRET_KEY:
        return jsonify({"status": "error", "error": "PAYSTACK_SECRET_KEY not set"}), 500

    if not wa_phone:
        return jsonify({"status": "error", "error": "wa_phone required"}), 400

    if plan not in PLAN_PRICES:
        return jsonify({"status": "error", "error": f"invalid plan. allowed={list(PLAN_PRICES.keys())}"}), 400

    try:
        # PLAN_PRICES should be in KOBO already (e.g., 3000 NGN => 300000 kobo)
        amount_kobo = int(PLAN_PRICES[plan])

        # 1) create local payment record
        local_payment = create_payment_record(wa_phone=wa_phone, plan=plan, amount_kobo=amount_kobo)
        reference = local_payment["reference"]

        # 2) call Paystack initialize
        payload = {
            "email": safe_email_from_phone(wa_phone),
            "amount": amount_kobo,
            "currency": CURRENCY,
            "reference": reference,
            "metadata": {
                "wa_phone": wa_phone,
                "plan": plan,
