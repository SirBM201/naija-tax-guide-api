def paystack_headers() -> Dict[str, str]:
    return {
        "Authorization": f"Bearer {PAYSTACK_SECRET_KEY}",
        "Content-Type": "application/json",
    }


def normalize_wa_phone(wa_phone: str) -> str:
    """
    Keep only digits and leading +, then standardize.
    You can customize this; Paystack doesn't care, but your DB matching does.
    """
    s = (wa_phone or "").strip()
    # keep + and digits only
    s = re.sub(r"[^\d+]", "", s)
    return s


def safe_email_from_phone(wa_phone: str) -> str:
    """
    Paystack requires an email. If you don't collect email yet,
    generate a valid placeholder email that won't break initialization.
    """
    digits = re.sub(r"\D", "", wa_phone or "")
    if not digits:
        digits = uuid.uuid4().hex[:10]
    return f"user_{digits}@naija-tax-guide.local"


def new_reference(prefix: str = "ntg") -> str:
    # Paystack reference must be unique; keep it readable
    return f"{prefix}_{uuid.uuid4().hex}"


def create_payment_record(wa_phone: str, plan: str, amount_kobo: int) -> Dict[str, Any]:
    """
    Inserts into public.payments using your actual schema.
    """
    ref = new_reference()
    row = {
        "reference": ref,
        "wa_phone": wa_phone,
        "provider": PROVIDER,
        "plan": plan,
        "amount_kobo": int(amount_kobo),
        "currency": CURRENCY,
        "status": "initiated",
        "raw_event": {"source": "initialize", "note": "created locally before paystack init"},
        # created_at defaults in DB if you set it; if not, you can set it here:
        # "created_at": iso(now_utc()),
    }

    res = supabase.table("payments").insert(row).execute()
    data = (res.data or [])
    # Return the inserted row (or at least the reference)
    if data:
        return data[0]
    return {"reference": ref}


